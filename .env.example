# Copy this file to .env and fill with your local values.
# Never commit .env files.

# Firebase project
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_APP_ID=your-web-app-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket

# Firebase web API key (for local/dev only if needed by scripts)
FIREBASE_WEB_API_KEY=your-web-api-key

# Optional CI secret (do not commit real value)
FIREBASE_TOKEN=your-firebase-ci-token
